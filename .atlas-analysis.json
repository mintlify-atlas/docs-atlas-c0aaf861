  "keyFeatures": [
    "Takeover-first design: adopts existing Minecraft servers before managing them",
    "Automatic dependency resolution and conflict handling",
    "Multi-source package access: Modrinth, CurseForge, GitHub, MCDR Plugin Catalog",
    "Soft manifest intent paired with exact lockfile facts",
    "Topology-aware server environment probing and risk surfacing",
    "Machine-readable JSON output for CI/CD pipelines",
    "Shell completion for bash, zsh, fish, and PowerShell",
    "Non-intrusive: all operations are independent of server runtime"
  ],
  "publicApiSurface": [
    "lucy init",
    "lucy add <platform/project@version>",
    "lucy remove <platform/project>",
    "lucy install",
    "lucy search <query>",
    "lucy status",
    "lucy info <platform/project@version>",
    "lucy cache ls",
    "lucy cache clear",
    ".lucy/config.toml",
    ".lucy/manifest.toml",
    ".lucy/lock.json"
